# // Database 

DB_CONNECTION= // Tipo de conexão com o banco de dados  - ex: mysql, pgsql, sqlite, sqlsrv
DB_DATABASE= // Nome do banco de dados  
DB_USERNAME= // Nome de usuário do banco de dados
DB_PASSWORD= // Senha do banco de dados - geralemnte vazio para ambiente de desenvolvimento
DB_HOST= // Host do banco de dados - ex: localhost